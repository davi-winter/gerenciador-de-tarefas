@model JobManagement.Models.Job

@{
    ViewData["Title"] = "Deletar";
}

<h2>@ViewData["Title"]</h2>
<hr></hr>

<h4>Tem certeza de que deseja excluir esta tarefa?</h4>

<div>
    <hr></hr>
    <dl class="d-flex flex-wrap">
        <dt class="w-25">
            @Html.DisplayNameFor(Model => Model.Description)
        </dt>
        <dd class="w-75">
            @Html.DisplayFor(Model => Model.Description)
        </dd>
        <dt class="w-25">
            @Html.DisplayNameFor(Model => Model.User)
        </dt>
        <dd class="w-75">
            @Html.DisplayFor(Model => Model.User.Name)
        </dd>
        <dt class="w-25">
            @Html.DisplayNameFor(Model => Model.Status)
        </dt>
        <dd class="w-75">
            @Html.DisplayFor(Model => Model.Status)
        </dd>
        <dt class="w-25">
            @Html.DisplayNameFor(Model => Model.Progress)
        </dt>
        <dd class="w-75">
            @Html.DisplayFor(Model => Model.Progress)
        </dd>
        <dt class="w-25">
            @Html.DisplayNameFor(Model => Model.Deadline)
        </dt>
        <dd class="w-75">
            @Html.DisplayFor(Model => Model.Deadline)
        </dd>
        <dt class="w-25">
            @Html.DisplayNameFor(Model => Model.Priority)
        </dt>
        <dd class="w-75">
            @Html.DisplayFor(Model => Model.Priority)
        </dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id"></input>
        <input type="submit" value="Delete" class="btn btn-danger"></input>
        <a href="javascript:history.back()">Voltar para Lista</a>
    </form>
</div>
