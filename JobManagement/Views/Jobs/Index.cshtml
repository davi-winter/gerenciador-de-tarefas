@model IEnumerable<JobManagement.Models.Job>

@{
    ViewData["Title"] = "Tarefas";
}

<head>
    <link rel="stylesheet" href="~/css/job.css" asp-append-version="true" />
</head>

<h2>@ViewData["Title"]</h2>
<hr></hr>

<p>
    <a asp-action="Create" class="btn btn-primary">Criar Nova</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr class="table-success">
            <th class="table-titles">
                <a asp-action="Index" asp-route-fieldOrder="Description" class="link-table-titles">@Html.DisplayNameFor(model => model.Description)</a>
            </th>
            <th class="table-titles">
                <a asp-action="Index" asp-route-fieldOrder="User" class="link-table-titles">@Html.DisplayNameFor(model => model.User)</a>
            </th>
            <th class="table-titles table-title-status">
                <a asp-action="Index" asp-route-fieldOrder="Status" class="link-table-titles">@Html.DisplayNameFor(model => model.Status)</a>
            </th>
            <th class="table-titles">
                <a asp-action="Index" asp-route-fieldOrder="Progress" class="link-table-titles">@Html.DisplayNameFor(model => model.Progress)</a>
            </th>
            <th class="table-titles">
                <a asp-action="Index" asp-route-fieldOrder="Deadline" class="link-table-titles">@Html.DisplayNameFor(model => model.Deadline)</a>
            </th>
            <th class="table-titles">
                <a asp-action="Index" asp-route-fieldOrder="Priority" class="link-table-titles">@Html.DisplayNameFor(model => model.Priority)</a>
            </th>
            <th>

            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.User.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Status)
                </td>
                <td>
                    <div class="progress-container">
                        <div class="progress-bar" style="width: @Html.DisplayFor(modelItem => item.Progress)%;"></div>
                        <span class="progress-text">@Html.DisplayFor(modelItem => item.Progress)%</span>
                    </div>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Deadline)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Priority)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-Id="@item.Id">Editar</a>
                    <a asp-action="Details" asp-route-Id="@item.Id">Detalhes</a>
                    <a asp-action="Delete" asp-route-Id="@item.Id">Deletar</a>
                </td>
            </tr>
        }
    </tbody>

</table>
